{
  "manifest_version": 3,
  "name": "FrontendDevHelper",
  "version": "1.2.0",
  "description": "A powerful browser extension for frontend developers with essential dev tools, color picker, layout inspector, and more.",
  "author": "FrontendDevHelper Team",
  "homepage_url": "https://github.com/rejisterjack/frontend-dev-helper",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "FrontendDevHelper",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "css": ["src/content/styles.css"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "scripting",
    "tabs",
    "clipboardWrite",
    "notifications",
    "sidePanel"
  ],
  "optional_permissions": [
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "icons/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; object-src 'self'; connect-src https://openrouter.ai"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Open FrontendDevHelper popup"
    },
    "open-command-palette": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Open Command Palette"
    },
    "toggle-pesticide": {
      "suggested_key": {
        "default": "Alt+P"
      },
      "description": "Toggle DOM Outliner"
    },
    "toggle-spacing": {
      "description": "Toggle Spacing Visualizer"
    },
    "toggle-font-inspector": {
      "description": "Toggle Font Inspector"
    },
    "toggle-color-picker": {
      "description": "Toggle Color Picker"
    },
    "toggle-pixel-ruler": {
      "description": "Toggle Pixel Ruler"
    },
    "toggle-breakpoint": {
      "description": "Toggle Breakpoint Overlay"
    },
    "toggle-inspector": {
      "description": "Toggle Element Inspector"
    },
    "toggle-css-inspector": {
      "description": "Toggle CSS Inspector"
    },
    "toggle-contrast-checker": {
      "description": "Toggle Contrast Checker"
    },
    "toggle-layout-visualizer": {
      "description": "Toggle Flex/Grid Visualizer"
    },
    "toggle-zindex-visualizer": {
      "description": "Toggle Z-Index Visualizer"
    },
    "toggle-tech-detector": {
      "description": "Toggle Tech Detector"
    },
    "toggle-accessibility-audit": {
      "description": "Toggle Accessibility Audit"
    },
    "toggle-network-analyzer": {
      "description": "Toggle Network Analyzer"
    },
    "toggle-screenshot-studio": {
      "description": "Toggle Screenshot Studio"
    },
    "toggle-ai-suggestions": {
      "description": "Toggle AI Suggestions"
    },
    "toggle-component-tree": {
      "description": "Toggle Component Tree"
    },
    "toggle-flame-graph": {
      "description": "Toggle Performance Flame Graph"
    },
    "toggle-storage-inspector": {
      "description": "Toggle Storage Inspector"
    },
    "toggle-focus-debugger": {
      "description": "Toggle Focus Debugger"
    },
    "toggle-form-debugger": {
      "description": "Toggle Form Debugger"
    },
    "toggle-visual-regression": {
      "description": "Toggle Visual Regression"
    },
    "disable-all-tools": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Disable All Tools"
    }
  },
  "minimum_chrome_version": "91",
  "update_url": "https://clients2.google.com/service/update2/crx"
}
