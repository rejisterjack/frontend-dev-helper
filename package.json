{
  "name": "frontend-dev-helper",
  "version": "1.2.0",
  "description": "A browser extension for frontend developers with essential dev tools",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "biome lint src",
    "lint:fix": "biome lint src --write",
    "format": "biome format src --write",
    "check": "biome check src",
    "check:fix": "biome check src --write",
    "release": "./scripts/build-release.sh",
    "release:win": "node scripts/build-release.js"
  },
  "keywords": [
    "browser-extension",
    "chrome-extension",
    "firefox-addon",
    "frontend",
    "developer-tools",
    "manifest-v3"
  ],
  "author": "FrontendDevHelper Team",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@crxjs/vite-plugin": "^2.0.0-beta.23",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.0.1",
    "@size-limit/time": "^12.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.0.254",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.0",
    "archiver": "^6.0.1",
    "autoprefixer": "^10.4.16",
    "jsdom": "^29.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.12.0",
    "zod": "^4.3.6"
  }
}
